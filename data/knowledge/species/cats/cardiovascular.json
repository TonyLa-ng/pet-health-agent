    "species": [
      "猫"
    ],
    "category": "心血管",
    "symptoms": {
      "primary": [
        "呼吸困难",
        "张口呼吸",
        "坐姿呼吸"
      ],
      "secondary": [
        "食欲下降",
        "精神萎靡",
        "后肢瘫痪（血栓）"
      ],
      "detail": {}
    },
    "urgency": "critical",
    "diagnosis_basis": "猫心衰最常见于HCM终末期。表现为肺水肿或胸水。猫心衰症状隐匿（不爱动/躲藏），易被忽视。X光（肺水肿/胸水）+心脏B超可确诊。",
    "home_care": "⚠️ 立即就医\n吸氧\n利尿剂（呋塞米）\n胸腔穿刺（如有胸水）\nACEI/β阻滞剂",
    "forbidden_care": [
      {
        "rule": "禁止应激",
        "condition": "default"
      },
      {
        "rule": "禁止不控制液体入量",
        "condition": "default"
      }
    ],
    "medication": [
      "需兽医处方"
    ],
    "vet_threshold": "症状加重或出现急症请立即就医",
    "confidence": "high",
    "differential_diagnosis": [
      {
        "disease": "猫哮喘",
        "differentiator": "哮喘无心脏扩大和心杂音，X光见支气管壁增厚而非肺水肿",
        "key_questions": [
          "有无心杂音？X光有无心脏扩大？"
        ]
      }
