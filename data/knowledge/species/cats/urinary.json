[
  {
    "id": "feline-urinary-001",
    "disease": "猫下泌尿道疾病/尿闭（FLUTD/FUS）",
    "species": [
      "猫"
    ],
    "category": "泌尿系统",
    "symptoms": {
      "primary": [
        "排尿困难",
        "完全无尿或仅滴尿",
        "频繁进猫砂盆但无尿",
        "膀胱胀大"
      ],
      "secondary": [
        "尿频",
        "血尿",
        "乱尿（排尿行为异常）",
        "排尿疼痛",
        "食欲下降",
        "精神萎靡",
        "过度舔舐生殖器",
        "呕吐",
        "腹部触诊敏感"
      ],
      "detail": {
        "排尿困难": {
          "frequency": "持续",
          "content": "频繁进出猫砂盆，长时间蹲坐但仅排少量尿液或完全无尿"
        },
        "乱尿": {
          "frequency": "高频",
          "content": "在猫砂盆以外的地方排尿（沙发/地板/床上）——这是猫排尿疼痛/困难的特征行为"
        },
        "血尿": {
          "frequency": "间歇",
          "content": "尿液呈粉红色或猫砂中出现红色团块"
        },
        "排尿疼痛": {
          "frequency": "伴随排尿",
          "content": "排尿时发出嚎叫或异常叫声"
        },
        "过度舔舐生殖器": {
          "frequency": "高频",
          "content": "因尿道不适反复舔舐生殖器区域"
        }
      }
    },
    "urgency": "critical",
    "diagnosis_basis": "猫下泌尿道疾病（FLUTD）是猫最常见的泌尿系统问题，公猫因尿道狭窄尤其容易发生完全阻塞（尿闭）。常见病因包括特发性膀胱炎（FIC，占50-60%）、膀胱结石（鸟粪石/草酸钙）、尿道栓子、细菌感染、肿瘤。公猫尿道阻塞是致命的急症，完全阻塞24-48小时可导致膀胱破裂、高钾血症和急性肾衰竭死亡。诊断依据：排尿困难+频繁进猫砂盆+乱尿行为+触诊膀胱充盈。需立即就医。",
    "home_care": "⚠️ 猫尿闭属于致命急症，以下建议仅供就医前临时参考：\n1. 立即停止自行处理，尽快前往24小时宠物医院\n2. 路途上避免按压猫的腹部\n3. 不要强行灌水\n4. 不要自行使用任何利尿剂或药物\n5. 观察猫是否还能排出少量尿液——完全无法排尿是最危险的信号",
    "forbidden_care": [
      {
        "rule": "禁止自行导尿或按压膀胱——可能导致膀胱破裂",
        "condition": "default"
      },
      {
        "rule": "禁止使用利尿剂或任何通淋药物",
        "condition": "default"
      },
      {
        "rule": "禁止强行灌水",
        "condition": "default"
      },
      {
        "rule": "禁止等待观察——猫尿闭24小时内可致命",
        "condition": "default"
      },
      {
        "rule": "禁止将猫的乱尿行为视为行为问题而惩罚——这是排尿疼痛/困难的表现",
        "condition": "default"
      }
    ],
    "medication": [
      "需兽医紧急处理后根据病因决定：解痉药/镇痛药/抗生素/处方粮（泌尿道配方），不可自行用药"
    ],
    "vet_threshold": "⚠️ 猫尿闭属于致命急症：1) 频繁进猫砂盆但无尿或仅几滴；2) 在任何异常位置排尿；3) 排尿时嚎叫；4) 超过12小时未见正常排尿；5) 腹部触诊膀胱胀大坚硬；6) 伴发呕吐、精神萎靡、体温下降。公猫完全阻塞24小时内未处理可能因高钾血症猝死。",
    "confidence": "high",
    "differential_diagnosis": [
      {
        "disease": "特发性膀胱炎（FIC，非阻塞性）",
        "differentiator": "FIC仍有排尿（可能带血），排尿通畅但频繁；环境应激是主要诱因；尿闭无法排出尿液，是急症",
        "key_questions": [
          "猫是否还能排出一些尿液？排尿量是否明显减少？"
        ]
      },
      {
        "disease": "膀胱结石（非阻塞性）",
        "differentiator": "结石可能未完全阻塞尿道，仍有尿液排出但带血；X光/B超可确诊结石位置和大小",
        "key_questions": [
          "猫之前是否有过泌尿问题？饮食类型是什么？"
        ]
      },
      {
        "disease": "急性肾衰竭",
        "differentiator": "肾衰竭初期多尿（代偿期），后期少尿/无尿；常伴明显全身症状；接触肾毒性物质史（百合花、防冻液、某些止痛药对猫剧毒）",
        "key_questions": [
          "猫有无可能接触百合花或其他植物？有无接触防冻液？"
        ]
      }
    ],
    "references": [
      "猫病学（第4版）",
      "猫下泌尿道疾病诊疗指南（ISFM/AAFP）"
    ],
