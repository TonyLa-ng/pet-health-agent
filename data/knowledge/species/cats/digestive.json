[
  {
    "id": "feline-gastritis-001",
    "disease": "急性胃炎",
    "species": [
      "猫"
    ],
    "category": "消化系统",
    "symptoms": {
      "primary": [
        "呕吐",
        "食欲下降",
        "精神萎靡"
      ],
      "secondary": [
        "腹泻",
        "脱水",
        "腹痛",
        "躲藏行为"
      ],
      "detail": {
        "呕吐": {
          "frequency": "高频",
          "content": "未消化食物/黄色胆汁/毛球/白色泡沫",
          "trigger": "进食后或空腹时"
        },
        "食欲下降": {
          "frequency": "持续",
          "content": "对食物无兴趣，甚至拒绝最爱的零食"
        },
        "精神萎靡": {
          "frequency": "持续",
          "content": "不爱活动，长时间卧睡，反应迟钝"
        },
        "腹泻": {
          "frequency": "间歇",
          "content": "软便/水样便，可能带黏液"
        },
        "躲藏行为": {
          "frequency": "持续",
          "content": "钻到角落或暗处不愿出来（猫疼痛/不适的特征行为）"
        },
        "脱水": {
          "frequency": "伴随",
          "content": "牙龈干燥、皮肤弹性下降"
        }
      }
    },
    "urgency": "medium",
    "diagnosis_basis": "猫急性胃炎是胃黏膜的急性炎症，常见病因包括毛球积聚、饮食不当（突然换粮、食物过敏）、应激（环境变化、新成员加入）、感染（细菌/病毒）、误食异物（线性异物在猫中尤其常见）。猫的胃炎需特别关注是否伴发胰腺炎（猫三联征：胃炎+肠炎+胰腺炎）。诊断主要依据临床症状和病史，需排除线性异物。",
    "home_care": "1. 短期禁食12-24小时（需保证饮水），让胃肠道休息\n2. 猫禁食超过24小时有肝脂肪变性风险，需谨慎\n3. 恢复进食时从少量易消化食物开始（白水煮鸡胸肉，少量多餐）\n4. 确保充足清洁饮水，可使用流动水或针管缓慢喂水\n5. 观察呕吐频率和精神状态变化\n6. 定期梳理毛发，减少毛球形成\n7. 如怀疑毛球问题，可使用猫用化毛膏",
    "forbidden_care": [
      {
        "rule": "禁食超过{hours}小时需兽医指导（猫禁食有肝脂肪变性风险）",
        "hours": 24,
        "condition": "default"
      },
      {
        "rule": "禁止自行使用人用止吐药",
        "condition": "default"
      },
      {
        "rule": "禁止强行灌食或灌水",
        "condition": "default"
      },
      {
        "rule": "禁止喂食洋葱、大蒜、巧克力、百合花等对猫有毒食物",
        "condition": "default"
      },
      {
        "rule": "禁止给猫使用犬用药物",
        "condition": "default"
      }
    ],
    "medication": [
      "止吐药（需兽医处方）",
      "胃黏膜保护剂（需兽医处方）",
      "化毛膏（如为毛球相关）"
    ],
    "vet_threshold": "以下情况需立即就医：1) 24小时内呕吐超过5次；2) 呕吐物带血或咖啡渣样；3) 伴发高热（>39.5℃）；4) 精神极度萎靡、无法站立；5) 幼猫/老年猫；6) 禁食24小时后症状无好转；7) 怀疑误食线性异物（绳、线、橡皮筋）；8) 伴发黄疸（口腔黏膜/眼白变黄）",
    "confidence": "high",
    "differential_diagnosis": [
      {
        "disease": "线性异物",
        "differentiator": "猫玩耍线、绳、橡皮筋后误食，可导致肠道套叠或穿孔；特征为剧烈呕吐+腹痛+完全不食；X光/B超/钡餐造影可确诊",
        "key_questions": [
          "猫是否有玩线、绳、橡皮筋等物品的习惯？",
          "家里有无缝纫用品被翻动痕迹？"
        ]
      },
      {
        "disease": "胰腺炎（猫三联征）",
        "differentiator": "猫胰腺炎常与胃炎、肠炎并发（三联征），症状重叠；血液fPLI检测+B超可鉴别",
        "key_questions": [
          "猫是否有肥胖史？是否近期进食过高脂肪食物？"
        ]
      },
      {
        "disease": "猫瘟（泛白细胞减少症）",
        "differentiator": "猫瘟以高热+剧烈呕吐+血便+白细胞极度下降为特征，未接种疫苗的幼猫高发；需试纸/ PCR确诊",
        "key_questions": [
          "猫是否完成疫苗接种？有无接触过未免疫的猫？"
        ]
      }
    ],
    "references": [
      "猫病学（第4版）",
      "BSAVA犬猫内科学手册"
    ],
