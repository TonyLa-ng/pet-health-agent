          "content": "下腹部膨隆，触诊有抵抗感"
        }
      }
    },
    "urgency": "critical",
    "diagnosis_basis": "犬尿闭是下泌尿道部分或完全阻塞导致的急症，常见原因包括膀胱结石、尿道结石、前列腺疾病（公犬）、肿瘤、尿道狭窄。完全阻塞24-48小时可导致膀胱破裂、急性肾衰竭，危及生命。诊断依据：排尿困难+尿频+触诊膀胱充盈。需立即就医进行导尿和影像学检查（X光/B超）。",
    "home_care": "⚠️ 尿闭属于宠物急症，以下建议仅供就医前临时参考：\n1. 立即停止自行处理，尽快前往24小时宠物医院\n2. 路途上避免按压宠物腹部\n3. 不要强行灌水（尿液无法排出时会加重肾脏负担）\n4. 不要自行使用利尿剂或任何药物",
    "forbidden_care": [
      {
        "rule": "禁止自行导尿或按压膀胱",
        "condition": "default"
      },
      {
        "rule": "禁止使用利尿剂或任何通淋药物",
        "condition": "default"
      },
      {
        "rule": "禁止强行灌水",
        "condition": "default"
      },
      {
        "rule": "禁止等待观察——尿闭是急症，拖延可能导致膀胱破裂和肾衰竭",
        "condition": "default"
      }
    ],
    "medication": [
      "需兽医诊断后根据病因决定：结石溶解药物/抗生素/α受体阻断剂等，不可自行用药"
    ],
    "vet_threshold": "⚠️ 尿闭属于急症，任何疑似尿闭的情况都需立即就医：1) 超过12小时无正常排尿；2) 反复尝试排尿但无尿液排出；3) 排尿时惨叫；4) 尿中带血；5) 腹部胀大、触诊硬实；6) 伴发呕吐、精神萎靡。完全阻塞24小时内未处理可导致膀胱破裂。",
    "confidence": "high",
    "differential_diagnosis": [
      {
        "disease": "膀胱炎（非阻塞性）",
        "differentiator": "膀胱炎仍可排尿（量可能正常），以尿频、尿急、血尿为主但排尿通畅；尿闭无法排出尿液",
        "key_questions": [
          "宠物是否还能正常排尿？排尿量是否正常？"
        ]
      },
      {
        "disease": "急性肾衰竭",
        "differentiator": "肾衰竭初期可能多尿，后期少尿/无尿；常伴明显全身症状（呕吐、口臭、口腔溃疡）；血液生化可确诊",
        "key_questions": [
          "宠物近期有无接触肾毒性物质（防冻液、葡萄、某些药物）？"
        ]
      },
      {
        "disease": "前列腺疾病（公犬）",
        "differentiator": "前列腺肿大压迫尿道也可导致排尿困难，通常见于未绝育老年公犬；直肠触诊+B超可鉴别",
        "key_questions": [
          "宠物是否绝育？年龄多大？"
        ]
      }
    ],
