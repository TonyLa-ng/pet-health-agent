          "frequency": "间歇",
          "content": "腹部触诊敏感，弓背姿势"
        }
      }
    },
    "urgency": "medium",
    "diagnosis_basis": "犬急性胃炎是胃黏膜的急性炎症，常见病因包括饮食不当（突然换粮、进食腐败食物、误食异物）、感染（细菌/病毒）、药物刺激、应激等。诊断主要依据临床症状（呕吐+食欲下降+精神萎靡）和病史（近期饮食变化）。需与肠道异物、胰腺炎、传染性疾病（细小病毒）鉴别。",
    "home_care": "1. 短期禁食12-24小时（需保证饮水），让胃肠道休息\n2. 恢复进食时从少量易消化食物开始（白水煮鸡胸肉+米饭，少量多餐）\n3. 确保充足清洁饮水，防止脱水\n4. 观察呕吐频率和精神状态变化\n5. 禁食期间如出现持续呕吐、精神恶化，需立即就医",
    "forbidden_care": [
      {
        "rule": "禁食超过{hours}小时需兽医指导",
        "hours": 24,
        "condition": "default"
      },
      {
        "rule": "禁食超过{hours}小时需兽医指导",
        "hours": 12,
        "condition": "puppy_or_small_breed"
      },
      {
        "rule": "禁止自行使用人用止吐药",
        "condition": "default"
      },
      {
        "rule": "禁止强行灌食或灌水",
        "condition": "default"
      },
      {
        "rule": "禁止喂食洋葱、大蒜、巧克力、葡萄等对犬有毒食物",
        "condition": "default"
      }
    ],
    "medication": [
      "止吐药（需兽医处方）",
      "胃黏膜保护剂（需兽医处方）",
      "益生菌（可在兽医指导下使用）"
    ],
    "vet_threshold": "以下情况需立即就医：1) 24小时内呕吐超过5次；2) 呕吐物带血或咖啡渣样；3) 伴发高热（>39.5℃）；4) 精神极度萎靡、无法站立；5) 幼犬/老年犬；6) 禁食24小时后症状无好转；7) 怀疑误食异物或毒物",
    "confidence": "high",
    "differential_diagnosis": [
      {
        "disease": "肠道异物",
        "differentiator": "异物通常引起剧烈呕吐+完全不食，X光或B超可确诊；胃炎呕吐通常在进食后发生",
        "key_questions": [
          "宠物是否有翻垃圾桶或啃咬玩具的习惯？",
          "排便是否正常？有无排便困难或便血？"
        ]
      },
      {
        "disease": "胰腺炎",
        "differentiator": "胰腺炎腹痛更剧烈（祈祷姿势），常伴发烧、黄疸；血液生化（淀粉酶/脂肪酶）可鉴别",
        "key_questions": [
          "宠物近期是否进食过高脂肪食物（肥肉/油炸食品）？",
          "有没有弓背祈祷的姿势？"
        ]
      },
      {
        "disease": "细小病毒感染",
        "differentiator": "细小病毒以血便+剧烈呕吐+白细胞下降为特征，幼犬高发，有特殊腥臭味；需试纸/ PCR确诊",
        "key_questions": [
          "宠物是否完成疫苗接种？",
          "腹泻有无带血或特殊腥臭味？"
        ]
      }
    ],
    "references": [
